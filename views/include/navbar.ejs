<!-- ════════════════════════════════════════
       NAVBAR
  ════════════════════════════════════════ -->
  <nav class="lx-nav">

    <a href="/" class="nav-brand">Travel<span>Nest</span></a>

    <!-- Desktop 3-segment search -->
    <div class="nav-search-desktop">
      <div class="search-seg">
        <label for="navSearchWhere">Where</label>
        <input
          type="text"
          id="navSearchWhere"
          placeholder="Any destination"
          autocomplete="off"
        >
      </div>
      <div class="search-seg">
        <label>When</label>
        <input type="text" placeholder="Any week" readonly>
      </div>
      <div class="search-seg">
        <label>Guests</label>
        <select>
          <option>Add guests</option>
          <option>1 guest</option>
          <option>2 guests</option>
          <option>3 guests</option>
          <option>4+ guests</option>
        </select>
      </div>
      <button class="nav-search-btn" type="button" id="navDesktopSearchBtn" aria-label="Search">
        <i class="fa-solid fa-magnifying-glass"></i>
      </button>
    </div>

    <!-- Mobile compact trigger -->
    <button
      class="nav-search-trigger"
      id="searchTrigger"
      type="button"
      aria-label="Open search"
    >
      <span class="trigger-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
      <span class="trigger-text">
        <span class="tl">Where to?</span>
        <span class="ts">Any destination · Any week</span>
      </span>
    </button>

    <!-- Nav actions -->
    <div class="nav-actions">
      <a href="/new" class="nav-link host-link">List your property</a>

      <% if (typeof currUser !== 'undefined' && currUser) { %>
        <a href="/wishlist" class="nav-link wishlist-link">
          <i class="fa-solid fa-heart" style="color:#e24b4a;font-size:13px"></i> Wishlist
        </a>
        <a href="/user/logout" class="nav-link user-link">
          <i class="fa-regular fa-circle-user" style="font-size:16px"></i>
          <%= currUser.username %>
        </a>
      <% } else { %>
        <a href="/user/login"  class="nav-link">Sign in</a>
        <a href="/user/singup" class="nav-link cta">Join free</a>
      <% } %>

      <div class="nav-avatar"><i class="fa-regular fa-user"></i></div>
    </div>

  </nav>


  <!-- ════════════════════════════════════════
       SEARCH POPUP OVERLAY
  ════════════════════════════════════════ -->
  <div class="search-overlay" id="searchOverlay">
    <div
      class="search-popup"
      role="dialog"
      aria-modal="true"
      aria-label="Search stays"
    >
      <button
        class="popup-close"
        id="popupClose"
        type="button"
        aria-label="Close search"
      >
        <i class="fa-solid fa-xmark"></i>
      </button>

      <div class="search-popup-inner">
        <div class="popup-heading">Find your <em>perfect</em> stay</div>

        <div class="popup-field">
          <label for="popupWhere">Where</label>
          <input
            type="text"
            id="popupWhere"
            class="popup-input"
            placeholder="City, country or neighbourhood…"
            autocomplete="off"
          >
        </div>

        <div class="popup-grid">
          <div class="popup-field">
            <label for="popupCheckIn">Check in</label>
            <input type="date" id="popupCheckIn" class="popup-input">
          </div>
          <div class="popup-field">
            <label for="popupCheckOut">Check out</label>
            <input type="date" id="popupCheckOut" class="popup-input">
          </div>
        </div>

        <div class="popup-field">
          <label for="popupGuests">Guests</label>
          <select id="popupGuests" class="popup-input">
            <option>Add guests</option>
            <option>1 guest</option>
            <option>2 guests</option>
            <option>3 guests</option>
            <option>4+ guests</option>
          </select>
        </div>

        <button class="popup-search-btn" id="popupSearchBtn" type="button">
          <i class="fa-solid fa-magnifying-glass" style="font-size:12px"></i>
          Search stays
        </button>
      </div>
    </div>
  </div>