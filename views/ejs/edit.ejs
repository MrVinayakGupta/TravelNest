<% layout("/layout/boilerplate") %>

<link rel="stylesheet" href="/css/edit.css">

<!-- ════════════════════════════════════════
     PAGE CONTENT
════════════════════════════════════════ -->
<div class="page-wrapper">

  <!-- Back link -->
  <a href="/<%= listing._id %>" class="return-link">
    <i class="fa-solid fa-arrow-left"></i> Discard &amp; return to listing
  </a>

  <!-- Edit card -->
  <div class="edit-container">

    <!-- Dark header band -->
    <div class="edit-header">
      <div class="edit-eyebrow">Host Workspace</div>
      <h1 class="edit-title">
        Refine Your <em>Extraordinary</em> Nest
      </h1>
    </div>

    <!-- Form body -->
    <div class="edit-body">

      <form
        method="POST"
        action="/listings/<%= listing._id %>?_method=PUT"
        enctype="multipart/form-data"
        class="needs-validation"
        novalidate
      >

        <!-- Title -->
        <div class="field-group">
          <label for="title" class="form-label">Property Title</label>
          <input
            name="listing[title]"
            value="<%= listing.title %>"
            type="text"
            class="form-control"
            id="title"
            placeholder="Give your property a captivating name"
            required
          >
          <div class="invalid-feedback">Please enter a property title.</div>
        </div>

        <!-- Description -->
        <div class="field-group">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listing[description]"
            rows="4"
            class="form-control"
            id="description"
            placeholder="Describe what makes this stay extraordinary…"
            required
          ><%= listing.description %></textarea>
          <div class="invalid-feedback">Please add a description.</div>
        </div>

        <!-- Category -->
        <div class="field-group">
          <label for="category" class="form-label">Category</label>
          <div class="select-wrap">
            <select name="listing[category]" class="form-select" id="category" required>
              <%
                var categories = [
                  "Trending","Rooms","Iconic Cities","Mountains",
                  "Amazing Pools","Beachfront","Farms","Arctic",
                  "Lakefront","Camping","Castles"
                ];
                categories.forEach(function(cat) {
              %>
                <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>>
                  <%= cat %>
                </option>
              <% }); %>
            </select>
          </div>
          <div class="invalid-feedback">Please select a category.</div>
        </div>

        <!-- Price + Location row -->
        <div class="form-row">

          <div class="field-group">
            <label for="price" class="form-label">Nightly Rate</label>
            <div class="price-wrap">
              <span class="price-symbol">&#8377;</span>
              <input
                name="listing[price]"
                value="<%= listing.price %>"
                type="number"
                class="form-control"
                id="price"
                placeholder="0"
                min="1"
                required
              >
            </div>
            <div class="invalid-feedback">Please enter a valid price.</div>
          </div>

          <div class="field-group">
            <label for="location" class="form-label">City / State</label>
            <input
              name="listing[location]"
              value="<%= listing.location %>"
              type="text"
              class="form-control"
              id="location"
              placeholder="e.g. Jaipur, Rajasthan"
              required
            >
            <div class="invalid-feedback">Please enter the location.</div>
          </div>

        </div>

        <!-- Country -->
        <div class="field-group">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            value="<%= listing.country %>"
            type="text"
            class="form-control"
            id="country"
            placeholder="e.g. India"
            required
          >
          <div class="invalid-feedback">Please enter the country.</div>
        </div>

        <!-- Image section -->
        <div class="img-section-label">
          <i class="fa-regular fa-image" style="color:var(--gold);font-size:13px"></i>
          Property Photography
        </div>

        <div class="img-grid">

          <!-- Current image -->
          <div>
            <div class="img-card-label">Current image</div>
            <div class="current-img-box">
              <img src="<%= listing.image.url %>" alt="Current listing image">
            </div>
          </div>

          <!-- New image preview -->
          <div>
            <div class="img-card-label">New image preview</div>
            <div class="preview-box" id="imagePreviewBox">
              <img id="imagePreview" src="#" alt="Preview">
            </div>
            <div class="preview-placeholder" id="previewPlaceholder" onclick="document.getElementById('image').click()">
              <i class="fa-solid fa-cloud-arrow-up"></i>
              <span>Click to preview</span>
            </div>
          </div>

        </div>

        <!-- File input -->
        <div class="field-group file-input-wrap">
          <label for="image" class="form-label">Upload new photo</label>
          <input
            name="listing[image]"
            type="file"
            class="form-control"
            id="image"
            accept="image/*"
            onchange="runPreview(event)"
          >
        </div>

        <div class="form-divider"></div>

        <button class="btn-update" type="submit">
          <i class="fa-solid fa-floppy-disk" style="font-size:13px"></i>
          Update My Nest
        </button>

      </form>

      <a href="/<%= listing._id %>" class="discard-link">
        <i class="fa-solid fa-xmark" style="font-size:10px;margin-right:5px"></i>
        Discard changes
      </a>

    </div><!-- /edit-body -->
  </div><!-- /edit-container -->

</div><!-- /page-wrapper -->

<!-- ════════════════════════════════════════
     FOOTER
════════════════════════════════════════ -->

<!-- ── PAGE SCRIPT ── -->
<script src="/js/edit.js"></script>
