<% layout("/layout/boilerplate") %>

<link rel="stylesheet" href="/css/singup.css">

<!-- ════════════════════════════════════════
     FULL-SCREEN BG + GLASS CARD
     (original design — auth-form untouched)
════════════════════════════════════════ -->
<main class="auth-main-bg">

  <div class="glass-card">

    <a href="javascript:history.back()" class="return-link-lux">
      <i class="fa-solid fa-arrow-left"></i> Return to previous
    </a>

    <div class="section-eyebrow">Join the Collection</div>
    <h1 class="form-title">Sign Up for <em>TravelNest</em></h1>

    <!-- ════════════════════════════════════
         AUTH FORM — ORIGINAL, UNCHANGED
         Only action typo fixed: singup→signup
    ════════════════════════════════════ -->
    <form id="signupForm" method="POST" action="/user/signup" class="needs-validation" novalidate>

      <div class="input-group">
        <label for="username" class="form-label-lux">Username</label>
        <input name="username" id="username" type="text"
               class="form-control-lux"
               placeholder="Choose a unique username"
               required autofocus autocomplete="username">
        <div class="invalid-feedback">Please choose a valid username.</div>
      </div>

      <div class="input-group">
        <label for="email" class="form-label-lux">Email Address</label>
        <input name="email" id="email" type="email"
               class="form-control-lux"
               placeholder="Enter your email"
               required autocomplete="email">
        <div class="invalid-feedback">Please provide a valid email address.</div>
      </div>

      <div class="input-group">
        <label for="password" class="form-label-lux">Password</label>
        <input name="password" id="password" type="password"
               class="form-control-lux"
               placeholder="Create a strong password"
               required autocomplete="new-password">
        <div class="invalid-feedback">Please enter a secure password.</div>
      </div>

      <button type="submit" class="btn-primary-lux">
        <i class="fa-solid fa-user-plus" style="font-size:11px"></i>
        Create Account
      </button>

    </form>
    <!-- /auth-form -->

    <div class="auth-footer-prompt">
      Already a member?<br><br>
      <a href="/user/login">Log In Instead</a>
    </div>

  </div>

</main>

<!-- ════════════════════════════════════════
     FOOTER
════════════════════════════════════════ -->

<!-- ── PAGE SCRIPT ── -->
<script src="/js/singup.js"></script>
