<% layout("/layout/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap">

<style>
    /* ═══════════════════════════════════════════
       LUXURY TOKENS
    ═══════════════════════════════════════════ */
    :root {
        --gold: #b8975a;
        --gold-light: #e0c98a;
        --gold-pale: #f7f1e6;
        --ink: #18160f;
        --ink-2: #3a3528;
        --ink-3: #7a7263;
        --surface: #fdfcf9;
        --border: #e8e2d6;
        --white: #ffffff;
        --font-serif: 'Cormorant Garamond', serif;
        --font-sans: 'DM Sans', sans-serif;
    }

    body {
        background: var(--surface);
        font-family: var(--font-sans);
        color: var(--ink);
    }

    /* ═══════════════════════════════════════════
       EXACT SAMPLE NAVBAR
    ═══════════════════════════════════════════ */
    .lx-nav {
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 2.5rem; height: 68px; background: var(--white);
        border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 1000;
    }

    .nav-brand {
        font-family: var(--font-serif); font-size: 26px; text-decoration: none; color: var(--ink);
        display: flex; align-items: center; gap: 8px;
    }
    .nav-brand span { color: var(--gold); font-style: italic; }

    .nav-search {
        display: flex; align-items: center; border: 1px solid var(--border);
        border-radius: 40px; padding: 0 6px 0 18px; height: 44px;
        background: var(--white); box-shadow: 0 2px 12px rgba(184,151,90,0.08);
    }

    .search-seg {
        display: flex; flex-direction: column; padding: 0 14px;
        border-right: 1px solid var(--border); cursor: pointer;
    }
    .search-seg:last-of-type { border-right: none; }
    .search-seg label {
        font-size: 9px; font-weight: 700; text-transform: uppercase;
        color: var(--ink-3); margin-bottom: -2px;
    }
    .search-seg input { border: none; outline: none; font-size: 12px; width: 85px; background: transparent; }

    .search-btn {
        width: 34px; height: 34px; background: var(--gold); border: none;
        border-radius: 50%; color: white; display: flex; align-items: center; justify-content: center;
    }

    .nav-actions { display: flex; align-items: center; gap: 1.5rem; }
    .nav-link { font-size: 13px; font-weight: 500; color: var(--ink); text-decoration: none; }

    /* ═══════════════════════════════════════════
       SIGN UP PAGE SPECIFICS
    ═══════════════════════════════════════════ */
    .auth-wrapper {
        min-height: calc(100vh - 68px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }

    .return-link {
        align-self: flex-start;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--ink-3);
        text-decoration: none;
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 2rem;
        transition: 0.3s;
    }

    .return-link:hover { color: var(--gold); transform: translateX(-5px); }

    .auth-card {
        background: var(--white);
        width: 100%;
        padding: 3.5rem;
        border-radius: 24px;
        border: 1px solid var(--border);
        box-shadow: 0 15px 40px rgba(0,0,0,0.04);
        animation: fadeUp 0.6s ease-out;
    }

    .auth-header { text-align: center; margin-bottom: 2.5rem; }
    
    .auth-header p {
        font-size: 11px; text-transform: uppercase; letter-spacing: 3px; 
        color: var(--gold); font-weight: 700; margin-bottom: 0.5rem;
    }

    .auth-header h3 {
        font-family: var(--font-serif); font-size: 40px; font-weight: 300; line-height: 1.2;
    }

    .auth-header h3 em { color: var(--gold); font-style: italic; }

    .form-label {
        font-size: 11px; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.1em; color: var(--ink-2); margin-bottom: 8px;
    }

    .form-control {
        border: 1px solid var(--border); border-radius: 12px;
        padding: 14px 18px; font-size: 14px; transition: 0.2s;
    }

    .form-control:focus {
        border-color: var(--gold); box-shadow: 0 0 0 4px rgba(184, 151, 90, 0.1); outline: none;
    }

    .btn-auth {
        background: var(--ink); color: var(--white); border: none;
        padding: 16px; border-radius: 50px; font-size: 12px; font-weight: 600;
        letter-spacing: 0.2em; text-transform: uppercase; width: 100%;
        margin-top: 1.5rem; transition: 0.4s;
    }

    .btn-auth:hover {
        background: var(--gold); transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(184, 151, 90, 0.2);
    }

    .login-prompt {
        text-align: center; margin-top: 2rem; font-size: 14px; color: var(--ink-3);
    }
    
    .login-prompt a {
        color: var(--gold); font-weight: 600; text-decoration: none;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .nav-search, .nav-actions .nav-link:first-child { display: none; }
        .lx-nav { padding: 0 1rem; }
        .auth-card { padding: 2rem 1.5rem; }
    }
</style>

<nav class="lx-nav">
    <a href="/" class="nav-brand">Travel<span>Nest</span></a>

    <div class="nav-search">
        <div class="search-seg">
            <label>Where</label>
            <input type="text" placeholder="Location">
        </div>
        <div class="search-seg">
            <label>When</label>
            <input type="text" placeholder="Add dates">
        </div>
        <div class="search-seg">
            <label>Guests</label>
            <input type="text" placeholder="Add guests">
        </div>
        <button class="search-btn"><i class="fa-solid fa-magnifying-glass"></i></button>
    </div>

    <div class="nav-actions">
        <a href="/new" class="nav-link">List your property</a>
        <a href="/user/login" class="nav-link"><i class="fa-regular fa-circle-user fs-4"></i></a>
    </div>
</nav>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7 col-sm-10">
            <div class="auth-wrapper">
                
                <a href="javascript:history.back()" class="return-link">
                    <i class="fa-solid fa-arrow-left"></i> Return to previous
                </a>

                <div class="auth-card">
                    <div class="auth-header">
                        <p>Join the Collection</p>
                        <h3>Sign Up for <em>TravelNest</em></h3>
                    </div>

                    <form method="POST" action="/user/singup" class="needs-validation" novalidate>
                        
                        <div class="mb-4">
                            <label for="username" class="form-label">Username</label>
                            <input name="username" placeholder="Choose a unique username" id="username" type="text" class="form-control" required autofocus>
                            <div class="invalid-feedback">Please choose a valid username.</div>
                        </div>

                        <div class="mb-4">
                            <label for="email" class="form-label">Email Address</label>
                            <input name="email" placeholder="Enter your email" id="email" type="email" class="form-control" required>
                            <div class="invalid-feedback">Please provide a valid email address.</div>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label">Password</label>
                            <input name="password" placeholder="Create a strong password" id="password" type="password" class="form-control" required>
                            <div class="invalid-feedback">Please enter a secure password.</div>
                        </div>

                        <button class="btn-auth" type="submit">Create Account</button>
                        
                    </form>

                    <div class="login-prompt">
                        Already a member? <a href="/user/login">Log In instead</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Bootstrap Client-Side Validation
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.needs-validation')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>