<% layout("/layout/boilerplate") %>

<link rel="stylesheet" href="/css/searchResult.css">

<!-- ════════════════════════════════════════
     HERO
════════════════════════════════════════ -->
<div class="search-hero">
  <div class="hero-eyebrow">Search results</div>
  <h1 class="search-headline">
    Stays for <em>"<%= query %>"</em>
  </h1>
  <div class="hero-meta">
    <span class="hero-count">
      <strong><%= results.length %></strong>
      <%= results.length === 1 ? 'property' : 'properties' %> found
    </span>
    <% if (results.length > 0) { %>
      <span class="hero-divider"></span>
      <span class="hero-count">Sorted by relevance</span>
    <% } %>
  </div>
</div>

<!-- ════════════════════════════════════════
     CONTROLS BAR
════════════════════════════════════════ -->
<% if (results.length > 0) { %>
<div class="controls-bar">
  <div class="filter-pills">
    <div class="fpill active" data-filter="all">All</div>
    <div class="fpill" data-filter="low">Price: Low first</div>
    <div class="fpill" data-filter="high">Price: High first</div>
    <div class="fpill" data-filter="rated">Top rated</div>
  </div>

  <div class="controls-right">
    <select class="sort-select" id="sortSelect">
      <option value="">Sort: Recommended</option>
      <option value="price-low">Price: Low to High</option>
      <option value="price-high">Price: High to Low</option>
    </select>
    <div class="view-toggle">
      <button class="vbtn active" id="gridViewBtn" title="Grid view">
        <i class="fa-solid fa-grip"></i>
      </button>
      <button class="vbtn" id="listViewBtn" title="List view">
        <i class="fa-solid fa-list"></i>
      </button>
    </div>
  </div>
</div>
<% } %>

<!-- ════════════════════════════════════════
     CARD GRID
════════════════════════════════════════ -->
<div class="card-grid" id="searchGrid">

  <% if (results.length > 0) { %>

    <% for (let i = 0; i < results.length; i++) { %>
      <% let listing = results[i]; %>
      <% let animClass = i % 3 === 0 ? 'from-left' : i % 3 === 2 ? 'from-right' : ''; %>

      <a href="/<%= listing._id %>"
         class="property-card <%= animClass %>"
         style="transition-delay:<%= (i % 4) * 70 %>ms;"
         data-price="<%= listing.price %>">

        <div class="card-img-wrap">
          <img
            src="<%= listing.image.url %>"
            alt="<%= listing.title %>"
            loading="<%= i < 4 ? 'eager' : 'lazy' %>"
          >
          <% if (i === 0) { %><div class="img-badge">Best match</div><% } %>
          <% if (i === 1) { %><div class="img-badge">Popular</div><% } %>
          <div class="img-rating">
            <i class="fa-solid fa-star"></i>
            <%= listing.reviews && listing.reviews.length > 0
              ? (listing.reviews.reduce((a,r) => a + r.rating, 0) / listing.reviews.length).toFixed(2)
              : '4.92' %>
          </div>
          <button
            class="save-btn"
            onclick="toggleSave(event,this)"
            type="button"
            aria-label="Save to wishlist">
            <i class="fa-regular fa-heart"></i>
          </button>
        </div>

        <div class="card-body">
          <div class="card-loc">
            <i class="fa-solid fa-location-dot"></i>
            <%= listing.location %>, <%= listing.country %>
          </div>
          <div class="card-title"><%= listing.title %></div>
          <div class="card-divider"></div>
          <div class="card-footer-row">
            <div class="price-main">
              &#8377;<%= listing.price.toLocaleString('en-IN') %><sub>&nbsp;/ night</sub>
            </div>
            <span class="explore-btn">
              Explore <i class="fa-solid fa-arrow-right" style="font-size:8px"></i>
            </span>
          </div>
        </div>

      </a>
    <% } %>

  <% } else { %>

    <div class="empty-state">
      <i class="fa-regular fa-compass"></i>
      <h3>No stays found for "<%= query %>"</h3>
      <p>Check your spelling or try a different city, country or neighbourhood.</p>
      <a href="/" class="back-link">
        <i class="fa-solid fa-arrow-left" style="font-size:9px"></i>
        Browse all stays
      </a>
      <div class="suggestions-row">
        <a href="/search?q=Goa"       class="suggestion-pill">Goa</a>
        <a href="/search?q=Manali"    class="suggestion-pill">Manali</a>
        <a href="/search?q=Jaipur"    class="suggestion-pill">Jaipur</a>
        <a href="/search?q=Kerala"    class="suggestion-pill">Kerala</a>
        <a href="/search?q=Shimla"    class="suggestion-pill">Shimla</a>
        <a href="/search?q=Rishikesh" class="suggestion-pill">Rishikesh</a>
      </div>
    </div>

  <% } %>

</div>

<!-- ════════════════════════════════════════
     FOOTER
════════════════════════════════════════ -->

<!-- ── PAGE SCRIPT ── -->
<script src="/js/searchResult.js"></script>
