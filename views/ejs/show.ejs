 <!-- layout("/layout/boilerplate") %> -->

<!-- ── FONTS & ICONS ── -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<!-- ── PAGE STYLESHEET ── -->
<link rel="stylesheet" href="/css/show.css">


<!-- ════════════════════════════════════════
     NAVBAR
════════════════════════════════════════ -->
<nav class="lx-nav">

  <a href="/" class="nav-brand">Travel<span>Nest</span></a>

  <!-- Desktop search pill -->
  <div class="nav-search">
    <div class="search-seg">
      <label>Where</label>
      <input type="text" placeholder="Any destination" autocomplete="off">
    </div>
    <div class="search-seg">
      <label>When</label>
      <input type="text" placeholder="Add dates" readonly>
    </div>
    <div class="search-seg">
      <label>Guests</label>
      <input type="text" placeholder="Add guests">
    </div>
    <button class="search-btn" type="button" id="desktopSearchBtn">
      <i class="fa-solid fa-magnifying-glass"></i>
    </button>
  </div>

  <!-- Mobile compact trigger -->
  <button class="nav-search-trigger" id="searchTrigger" type="button" aria-label="Open search">
    <span class="trigger-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
    <span class="trigger-text">
      <span class="tl">Search stays</span>
      <span class="ts">Anywhere · Any time</span>
    </span>
  </button>

  <div class="nav-actions">
    <a href="/new" class="nav-link">List your property</a>
    
    <% if (currUser) { %>
      <a href="/wishlist" class="nav-link wishlist-link">
        <i class="fa-solid fa-heart" style="color:#e24b4a"></i> Wishlist
      </a>
      <a href="/user/profile" class="nav-link">
        <i class="fa-regular fa-circle-user" style="font-size:16px"></i>
        <%= currUser.username %>
      </a>
    <% } else { %>
      <a href="/user/login" class="nav-link ">Sign in</a>
      <a href="/user/singup" class="nav-link cta">Join free</a>
    <% } %>
  </div>

</nav>


<!-- ════════════════════════════════════════
     SEARCH POPUP
════════════════════════════════════════ -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-popup" role="dialog" aria-modal="true" aria-label="Search stays">
    <button class="popup-close" id="popupClose" type="button" aria-label="Close">
      <i class="fa-solid fa-xmark"></i>
    </button>
    <div class="search-popup-inner">
      <div class="popup-heading">Find your <em>perfect</em> stay</div>
      <div class="popup-field">
        <label for="popupWhere">Where</label>
        <input type="text" id="popupWhere" class="popup-input" placeholder="City, country or area…" autocomplete="off">
      </div>
      <div class="popup-grid">
        <div class="popup-field">
          <label for="popupCheckIn">Check in</label>
          <input type="date" id="popupCheckIn" class="popup-input">
        </div>
        <div class="popup-field">
          <label for="popupCheckOut">Check out</label>
          <input type="date" id="popupCheckOut" class="popup-input">
        </div>
      </div>
      <div class="popup-field">
        <label for="popupGuests">Guests</label>
        <select id="popupGuests" class="popup-input">
          <option>Add guests</option>
          <option>1 guest</option>
          <option>2 guests</option>
          <option>3 guests</option>
          <option>4+ guests</option>
        </select>
      </div>
      <button class="popup-search-btn" id="popupSearchBtn" type="button">
        <i class="fa-solid fa-magnifying-glass" style="font-size:12px"></i>
        Search stays
      </button>
    </div>
  </div>
</div>


<!-- ════════════════════════════════════════
     CATEGORY / BREADCRUMB STRIP
════════════════════════════════════════ -->
<div class="category-strip">
  <div class="cat-crumb">
    <a href="/">Home</a>
    <span class="cat-sep">/</span>
    <a href="/?filter=<%= listing.category ? listing.category.toLowerCase() : 'all' %>">
      <%= listing.category || 'All Stays' %>
    </a>
    <span class="cat-sep">/</span>
    <span style="color:var(--ink-2);font-weight:500"><%= listing.title %></span>
  </div>

  <div class="cat-tags">
    <% if (listing.category) { %>
      <span class="cat-badge">
        <i class="fa-solid fa-tag"></i>
        <%= listing.category %>
      </span>
    <% } %>
    <span class="cat-tag">
      <i class="fa-solid fa-location-dot" style="font-size:9px;color:var(--gold);margin-right:3px"></i>
      <%= listing.country %>
    </span>
    <span class="cat-tag" style="color:var(--gold);border-color:var(--gold-light);background:var(--gold-pale)">
      <i class="fa-solid fa-star" style="font-size:9px;margin-right:3px"></i>
      <%= listing.reviews && listing.reviews.length > 0 ? listing.reviews.length + ' reviews' : 'New listing' %>
    </span>
  </div>
</div>


<!-- ════════════════════════════════════════
     MAIN HERO
════════════════════════════════════════ -->
<div class="show-wrapper">
  <div class="listing-hero" id="mainHero">

    <!-- Image column -->
    <div class="hero-img-col">
      <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
      <div class="img-overlay-bar">
        <div class="img-location-tag">
          <i class="fa-solid fa-location-dot"></i>
          <%= listing.location %>, <%= listing.country %>
        </div>
        <button class="img-save-btn" id="heroSaveBtn" type="button" onclick="toggleHeroSave()">
          <i class="fa-regular fa-heart"></i>
        </button>
      </div>
    </div>

    <!-- Content column -->
    <div class="hero-content">
      <div>
        <div class="owner-tag">
          Exclusively curated by @<%= listing.owner.username %>
        </div>

        <h1 class="listing-title"><%= listing.title %></h1>

        <div class="meta-row">
          <span class="meta-chip">
            <i class="fa-solid fa-location-dot"></i>
            <%= listing.location %>
          </span>
          <% if (listing.category) { %>
            <span class="meta-chip">
              <i class="fa-solid fa-tag"></i>
              <%= listing.category %>
            </span>
          <% } %>
          <span class="meta-chip">
            <i class="fa-solid fa-star"></i>
            <%= listing.reviews && listing.reviews.length > 0 ? listing.reviews.length + ' reviews' : 'No reviews yet' %>
          </span>
        </div>

        <p class="listing-desc"><%= listing.description %></p>
      </div>

      <div>
        <!-- Price (hidden on mobile — shown in sticky bar instead) -->
        <div class="price-section">
          <div class="price-label">Starting from</div>
          <div class="price-main">
            &#8377;<%= listing.price.toLocaleString('en-IN') %>
            <small>/ night</small>
          </div>
          <div class="price-tax">
            &#8377;<%= Math.round(listing.price * 1.18).toLocaleString('en-IN') %> total incl. taxes
          </div>
        </div>

        <!-- Actions (hidden on mobile — replaced by sticky bar) -->
        <div class="action-row">
          <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
            <a href="/<%= listing._id %>/edit" class="btn-primary-lux">
              <i class="fa-solid fa-pen" style="font-size:10px"></i> Edit stay
            </a>
            <form method="POST" action="/<%= listing._id %>?_method=DELETE" style="flex:1;min-width:100px">
              <button type="submit" class="btn-ghost-lux" style="width:100%">
                <i class="fa-solid fa-trash" style="font-size:10px"></i> Remove
              </button>
            </form>
          <% } else { %>
            <button class="btn-primary-lux"
              onclick="document.getElementById('reviewForm').scrollIntoView({behavior:'smooth'})">
              <i class="fa-solid fa-star" style="font-size:10px"></i> Book now
            </button>
            <button class="btn-ghost-lux" onclick="toggleHeroSave()">
              <i class="fa-regular fa-heart" id="saveIconBtn" style="font-size:10px"></i> Save stay
            </button>
          <% } %>
        </div>
      </div>
    </div>

  </div><!-- /listing-hero -->


  <!-- ════════════════════════════════════════
       REVIEWS SECTION
  ════════════════════════════════════════ -->
  <div class="section-divider"><span>Guest impressions</span></div>

  <div class="reviews-container">
    <div class="section-header">
      <div class="section-eyebrow">What guests say</div>
      <h2 class="section-title">Guest <em>Experiences</em></h2>
    </div>

    <div class="reviews-layout">

      <!-- Review form -->
      <% if (currUser) { %>
        <div class="review-form-card" id="reviewForm">
          <div class="form-eyebrow">Share your stay</div>
          <div class="form-title">Leave an <em>Impression</em></div>

          <form action="/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
            <div style="margin-bottom:1.25rem">
              <label class="form-label-lux">Your rating</label>
              <div class="star-row" id="starRow">
                <button type="button" class="star-btn" data-val="1">&#9733;</button>
                <button type="button" class="star-btn" data-val="2">&#9733;</button>
                <button type="button" class="star-btn" data-val="3">&#9733;</button>
                <button type="button" class="star-btn" data-val="4">&#9733;</button>
                <button type="button" class="star-btn" data-val="5">&#9733;</button>
              </div>
              <input type="hidden" name="review[rating]" id="starInput" value="1" required>
            </div>

            <div style="margin-bottom:1.5rem">
              <label class="form-label-lux" for="comment">Your thoughts</label>
              <textarea
                name="review[comment]"
                id="comment"
                class="form-control-lux"
                rows="4"
                placeholder="Share your experience with this stay…"
                required></textarea>
              <input type="text" name="review[author]" value="<%= currUser._id %>" hidden>
            </div>

            <button type="submit" class="btn-primary-lux" style="width:100%;justify-content:center">
              <i class="fa-solid fa-paper-plane" style="font-size:10px"></i> Submit review
            </button>
          </form>
        </div>

      <% } else { %>
        <div style="background:var(--gold-pale);border:1px solid var(--gold-light);border-radius:18px;padding:2rem;text-align:center" id="reviewForm">
          <i class="fa-regular fa-comment-dots" style="font-size:28px;color:var(--gold-light);margin-bottom:12px;display:block"></i>
          <div style="font-family:var(--ff-serif);font-size:1.5rem;margin-bottom:8px">
            Share your <em style="color:var(--gold)">experience</em>
          </div>
          <p style="font-size:13px;color:var(--ink-3);margin-bottom:1.25rem">
            Sign in to leave a review for this stay.
          </p>
          <a href="/user/login" class="btn-primary-lux" style="display:inline-flex">Sign in to review</a>
        </div>
      <% } %>

      <!-- Reviews list -->
      <div>
        <% if (listing.reviews.length === 0) { %>
          <div class="no-reviews">
            <i class="fa-regular fa-star"></i>
            No reviews yet — be the first to leave one.
          </div>
        <% } else { %>
          <div class="reviews-grid">
            <% for (let review of listing.reviews) { %>
              <div class="review-card">
                <div class="review-author">
                  <div class="reviewer-avatar">
                    <%= review.author ? review.author.username[0].toUpperCase() : 'G' %>
                  </div>
                  <div>
                    <div class="reviewer-name">@<%= review.author.username %></div>
                    <div class="reviewer-tag">Verified guest</div>
                  </div>
                </div>

                <div class="review-stars">
                  <% for (let s = 1; s <= 5; s++) { %>
                    <i class="fa-solid fa-star <%= s <= review.rating ? '' : 'empty' %>"></i>
                  <% } %>
                </div>

                <p class="review-text"><%= review.comment %></p>

                <% if (currUser && currUser._id.equals(review.author._id)) { %>
                  <form method="POST" action="/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                    <button type="submit" class="review-remove-btn">
                      <i class="fa-solid fa-trash" style="font-size:9px;margin-right:4px"></i>Remove review
                    </button>
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

    </div>
  </div><!-- /reviews-container -->


  <!-- ════════════════════════════════════════
       RELATED LISTINGS DIVIDER
  ════════════════════════════════════════ -->
  <div class="section-divider"><span>More to explore</span></div>

</div><!-- /show-wrapper -->


<!-- ════════════════════════════════════════
     RELATED LISTINGS
════════════════════════════════════════ -->
<div class="related-section">
  <div class="section-header">
    <div class="section-eyebrow">You may also love</div>
    <h2 class="section-title">Other <em>Extraordinary</em> Stays</h2>
  </div>

  <div class="related-grid" id="relatedGrid">
    <%
      let related = [];
      if (typeof allListings !== 'undefined' && allListings) {
        related = allListings.filter(l => {
          if (l._id.toString() === listing._id.toString()) return false;
          const sameCountry  = l.country === listing.country;
          const sameCategory = listing.category && l.category === listing.category;
          return sameCountry || sameCategory;
        }).slice(0, 8);

        if (related.length < 4) {
          const extras = allListings.filter(l =>
            l._id.toString() !== listing._id.toString() &&
            !related.some(r => r._id.toString() === l._id.toString())
          ).slice(0, 8 - related.length);
          related = [...related, ...extras];
        }
      }
    %>

    <% if (related.length === 0) { %>
      <div style="grid-column:1/-1;text-align:center;padding:3rem;font-family:var(--ff-serif);font-size:1.4rem;color:var(--ink-3)">
        No other stays to show right now.
      </div>
    <% } %>

    <% for (let i = 0; i < related.length; i++) { %>
      <% let r = related[i]; %>
      <% let animDir = i % 3 === 0 ? 'fl' : i % 3 === 2 ? 'fr' : ''; %>
      <a href="/<%= r._id %>"
         class="rel-card <%= animDir %>"
         style="transition-delay:<%= (i % 4) * 65 %>ms">
        <div class="rel-img">
          <img src="<%= r.image.url %>" alt="<%= r.title %>" loading="lazy">
          <% if (r.category) { %>
            <div class="rel-badge"><%= r.category %></div>
          <% } %>
          <div class="rel-rating">
            <i class="fa-solid fa-star"></i>
            <%= r.reviews && r.reviews.length > 0
              ? (r.reviews.reduce((a,rv) => a + rv.rating, 0) / r.reviews.length).toFixed(1)
              : '4.9' %>
          </div>
          <button class="rel-wishlist" onclick="toggleWish(event,this)" type="button">
            <i class="fa-regular fa-heart"></i>
          </button>
        </div>
        <div class="rel-body">
          <div class="rel-loc">
            <i class="fa-solid fa-location-dot"></i>
            <%= r.location %>, <%= r.country %>
          </div>
          <div class="rel-title"><%= r.title %></div>
          <div class="rel-footer">
            <div class="rel-price">
              &#8377;<%= r.price.toLocaleString('en-IN') %><sub>&nbsp;/ night</sub>
            </div>
            <span class="rel-cta">
              Explore <i class="fa-solid fa-arrow-right" style="font-size:8px"></i>
            </span>
          </div>
        </div>
      </a>
    <% } %>
  </div>

  <div style="text-align:center;margin-top:2.5rem">
    <a href="/" class="btn-ghost-lux" style="display:inline-flex">
      <i class="fa-solid fa-compass" style="font-size:11px"></i> Browse all stays
    </a>
  </div>
</div>


<!-- ════════════════════════════════════════
     FOOTER
════════════════════════════════════════ -->
<footer class="site-footer">
  <div class="footer-brand">TravelNest</div>
  <div class="footer-links">
    <a href="/about">About</a>
    <a href="/privacy">Privacy</a>
    <a href="/terms">Terms</a>
    <a href="/help">Help</a>
  </div>
  <div>&copy; <%= new Date().getFullYear() %> TravelNest. All rights reserved.</div>
</footer>


<!-- ════════════════════════════════════════
     MOBILE STICKY BOOKING BAR
     (visible only on mobile, fixed at bottom)
════════════════════════════════════════ -->
<div class="mobile-book-bar" id="mobileBookBar">
  <div class="mobile-book-price">
    <div class="mprice">
      &#8377;<%= listing.price.toLocaleString('en-IN') %><sub>&nbsp;/ night</sub>
    </div>
    <div class="mtax">
      &#8377;<%= Math.round(listing.price * 1.18).toLocaleString('en-IN') %> incl. taxes
    </div>
  </div>
  <div style="display:flex;gap:10px;align-items:center">
    <!-- Save icon on mobile bar -->
    <button type="button"
      onclick="toggleHeroSave()"
      style="width:42px;height:42px;border-radius:50%;background:var(--surface-2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--ink-3);transition:color .2s,border-color .2s;flex-shrink:0"
      aria-label="Save to wishlist">
      <i class="fa-regular fa-heart" id="mobileSaveIcon"></i>
    </button>
    <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
      <a href="/<%= listing._id %>/edit" class="mobile-book-btn" style="text-decoration:none">
        Edit stay
      </a>
    <% } else { %>
      <button class="mobile-book-btn" id="mobileBookBtn" type="button">
        Book now
      </button>
    <% } %>
  </div>
</div>


<!-- ── PAGE SCRIPT ── -->
<script src="/js/show.js"></script>
