<% layout("/layout/boilerplate") %>

<link rel="stylesheet" href="/css/home.css">

<!-- ════════════════════════════════════════
     FILTER BAR
════════════════════════════════════════ -->
<div class="filter-bar" id="filterBar">

  <div class="filter-scroll" id="filterScroll">
    <a href="?filter=trending"   class="filter-pill active" data-filter="trending">
      <i class="fa-solid fa-fire"></i><span>Trending</span>
    </a>
    <a href="?filter=rooms"      class="filter-pill" data-filter="rooms">
      <i class="fa-solid fa-bed"></i><span>Rooms</span>
    </a>
    <a href="?filter=cities"     class="filter-pill" data-filter="cities">
      <i class="fa-solid fa-city"></i><span>Iconic Cities</span>
    </a>
    <a href="?filter=mountain"   class="filter-pill" data-filter="mountain">
      <i class="fa-solid fa-mountain"></i><span>Mountain</span>
    </a>
    <a href="?filter=castles"    class="filter-pill" data-filter="castles">
      <i class="fa-brands fa-fort-awesome"></i><span>Castles</span>
    </a>
    <a href="?filter=pool"       class="filter-pill" data-filter="pool">
      <i class="fa-solid fa-person-swimming"></i><span>Amazing Pool</span>
    </a>
    <a href="?filter=camping"    class="filter-pill" data-filter="camping">
      <i class="fa-regular fa-compass"></i><span>Camping</span>
    </a>
    <a href="?filter=farms"      class="filter-pill" data-filter="farms">
      <i class="fa-solid fa-tractor"></i><span>Farms</span>
    </a>
    <a href="?filter=snow"       class="filter-pill" data-filter="snow">
      <i class="fa-solid fa-snowman"></i><span>Snow</span>
    </a>
    <a href="?filter=beachfront" class="filter-pill" data-filter="beachfront">
      <i class="fa-solid fa-umbrella-beach"></i><span>Beachfront</span>
    </a>
    <a href="?filter=luxury"     class="filter-pill" data-filter="luxury">
      <i class="fa-solid fa-gem"></i><span>Luxury</span>
    </a>
    <a href="?filter=forest"     class="filter-pill" data-filter="forest">
      <i class="fa-solid fa-tree"></i><span>Forest</span>
    </a>
  </div>

  <label class="tax-wrap">
    <div class="toggle-switch">
      <input type="checkbox" id="switchCheckDefault" role="switch">
      <span class="toggle-track"></span>
    </div>
    <span class="tax-label">Show total with taxes</span>
  </label>

</div>

<!-- ════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════ -->
<div class="hero-banner">
  <div>
    <h1 class="hero-headline">
      Find your next<br><em>extraordinary</em> stay
    </h1>
    <p class="hero-sub">Curated stays from around the world</p>
  </div>
  <div class="hero-count">
    <div class="big-num" id="listingCount"><%= allListings.length %></div>
    <div class="big-label">Properties available</div>
  </div>
</div>

<!-- ════════════════════════════════════════
     CONTROLS ROW
════════════════════════════════════════ -->
<div class="controls-row">
  <select class="sort-select" id="sortSelect">
    <option value="">Sort: Recommended</option>
    <option value="price-low">Price: Low to High</option>
    <option value="price-high">Price: High to Low</option>
    <option value="rating">Top Rated</option>
  </select>

  <div class="view-toggle">
    <button class="view-btn active" id="gridViewBtn" title="Grid view">
      <i class="fa-solid fa-grip"></i>
    </button>
    <button class="view-btn" id="listViewBtn" title="List view">
      <i class="fa-solid fa-list"></i>
    </button>
  </div>
</div>

<!-- ════════════════════════════════════════
     PROPERTY CARDS
════════════════════════════════════════ -->
<div class="card-grid" id="cardGrid">

  <% for (let i = 0; i < allListings.length; i++) { %>
    <% let listing = allListings[i]; %>
    <% let taxPrice = Math.round(listing.price * 1.18); %>
    <% let animClass = i % 3 === 0 ? 'from-left' : i % 3 === 2 ? 'from-right' : ''; %>

    <a href="/<%= listing._id %>"
       class="property-card <%= animClass %>"
       style="transition-delay: <%= (i % 4) * 70 %>ms;"
       data-price="<%= listing.price %>"
       data-title="<%= listing.title %>">

      <div class="card-img-wrap">
        <img
          src="<%= listing.image.url %>"
          alt="<%= listing.title %>"
          loading="<%= i < 4 ? 'eager' : 'lazy' %>"
        >

        <% if (i < 3) { %>
          <div class="img-badge">
            <%= i === 0 ? "Editor's Pick" : i === 1 ? "Rare Find" : "New" %>
          </div>
        <% } %>

        <div class="img-rating">
          <i class="fa-solid fa-star"></i>
          <%= listing.rating ? listing.rating.toFixed(2) : "4.92" %>
        </div>

        <button class="save-btn" onclick="toggleSave(event, this)" aria-label="Save to wishlist" type="button">
          <i class="fa-regular fa-heart"></i>
        </button>
      </div>

      <div class="card-body">
        <div class="card-loc">
          <i class="fa-solid fa-location-dot"></i>
          <%= listing.location %>, <%= listing.country %>
        </div>

        <div class="card-title"><%= listing.title %></div>

        <div class="card-divider"></div>

        <div class="card-footer-row">
          <div class="price-block">
            <div class="price-main">
              &#8377;<%= listing.price.toLocaleString('en-IN') %><sub>&nbsp;/ night</sub>
            </div>
            <div class="price-tax">
              &#8377;<%= taxPrice.toLocaleString('en-IN') %> incl. taxes
            </div>
          </div>
          <span class="explore-btn">
            Explore <i class="fa-solid fa-arrow-right" style="font-size:10px"></i>
          </span>
        </div>
      </div>

    </a>
  <% } %>

  <div class="empty-state" id="emptyState">
    <i class="fa-regular fa-compass"></i>
    <h3>No stays found</h3>
    <p>Try a different filter or search term</p>
  </div>

</div>

<!-- ════════════════════════════════════════
     FOOTER
════════════════════════════════════════ -->

<!-- ── PAGE SCRIPT ── -->
<script src="/js/home.js"></script>
