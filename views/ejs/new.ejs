<% layout("/layout/boilerplate") %>

<!-- ── PAGE STYLESHEET ── -->
<link rel="stylesheet" href="/css/new.css">


<!-- ════════════════════════════════════════
     PAGE CONTENT
════════════════════════════════════════ -->
<div class="page-wrapper">

  <!-- Back link -->
  <a href="javascript:history.back()" class="back-nav">
    <i class="fa-solid fa-arrow-left"></i> Return to previous
  </a>

  <!-- Form card -->
  <div class="form-container">

    <!-- Dark header band -->
    <div class="form-header">
      <div class="form-eyebrow">Host Portal</div>
      <h1 class="form-title">
        Create an <em>Extraordinary</em> Listing
      </h1>
    </div>

    <!-- Form body -->
    <div class="form-body">

      <form
        method="POST"
        action="/listings"
        class="needs-validation"
        novalidate
        enctype="multipart/form-data"
      >

        <!-- Title -->
        <div class="field-group">
          <label for="title" class="form-label">Property Title</label>
          <input
            name="listing[title]"
            type="text"
            class="form-control"
            id="title"
            placeholder="e.g. The Glass House above the clouds"
            required
          >
          <div class="invalid-feedback">Please give your property a title.</div>
        </div>

        <!-- Description -->
        <div class="field-group">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listing[description]"
            rows="4"
            class="form-control"
            id="description"
            placeholder="Describe the soul of this place — what makes it unforgettable?"
            required
          ></textarea>
          <div class="invalid-feedback">Please add a description.</div>
        </div>

        <!-- Image upload -->
        <div class="field-group">
          <div class="img-section-label">
            <i class="fa-regular fa-image" style="color:var(--gold);font-size:13px"></i>
            Property Photography
          </div>

          <!-- Preview (hidden until file chosen) -->
          <div class="preview-box" id="imagePreviewBox">
            <img id="imagePreview" src="#" alt="Preview">
            <div class="preview-badge" id="previewBadge">
              <i class="fa-solid fa-check" style="font-size:9px"></i> Ready to upload
            </div>
            <button
              type="button"
              class="preview-remove"
              id="previewRemove"
              aria-label="Remove image"
            >
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>

          <!-- Upload zone (drag & drop or click) -->
          <div class="upload-zone" id="uploadZone">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <div class="uz-title">Drop your photo here, or click to browse</div>
            <div class="uz-sub">High-quality .jpg or .png · Recommended 1920×1080+</div>
            <!-- real file input sits over the zone -->
            <input
              name="listing[image]"
              type="file"
              id="image"
              accept="image/*"
              onchange="runPreview(event)"
            >
          </div>

          <!-- File name chip -->
          <div class="file-chip" id="fileChip">
            <i class="fa-regular fa-file-image"></i>
            <span id="chipName"></span>
          </div>
        </div>

        <!-- Category -->
        <div class="field-group">
          <label for="category" class="form-label">Curated Category</label>
          <div class="select-wrap">
            <select name="listing[category]" class="form-select" id="category" required>
              <option value="" selected disabled>Select atmosphere…</option>
              <option value="Trending">Trending</option>
              <option value="Rooms">Rooms</option>
              <option value="Iconic Cities">Iconic Cities</option>
              <option value="Mountains">Mountains</option>
              <option value="Amazing Pools">Amazing Pools</option>
              <option value="Beachfront">Beachfront</option>
              <option value="Farms">Farms</option>
              <option value="Arctic">Arctic</option>
              <option value="Lakefront">Lakefront</option>
              <option value="Camping">Camping</option>
              <option value="Castles">Castles</option>
            </select>
          </div>
          <div class="invalid-feedback">Please select a category.</div>
        </div>

        <!-- Price + Location row -->
        <div class="form-row">

          <div class="field-group">
            <label for="price" class="form-label">Price / Night</label>
            <div class="price-wrap">
              <span class="price-symbol">&#8377;</span>
              <input
                name="listing[price]"
                type="number"
                class="form-control"
                id="price"
                placeholder="1500"
                min="1"
                required
              >
            </div>
            <div class="invalid-feedback">Please enter a valid price.</div>
          </div>

          <div class="field-group">
            <label for="location" class="form-label">City / State</label>
            <input
              name="listing[location]"
              type="text"
              class="form-control"
              id="location"
              placeholder="e.g. Jaipur, Rajasthan"
              required
            >
            <div class="invalid-feedback">Please enter the location.</div>
          </div>

        </div>

        <!-- Country -->
        <div class="field-group">
          <label for="country" class="form-label">Country</label>
          <input
            name="listing[country]"
            type="text"
            class="form-control"
            id="country"
            placeholder="e.g. India"
            required
          >
          <div class="invalid-feedback">Please enter the country.</div>
        </div>

        <div class="form-divider"></div>

        <button class="btn-create" type="submit">
          <i class="fa-solid fa-circle-plus" style="font-size:14px"></i>
          Publish to TravelNest
        </button>

      </form>

    </div><!-- /form-body -->
  </div><!-- /form-container -->

</div><!-- /page-wrapper -->


<!-- ── PAGE SCRIPT ── -->
<script src="/js/new.js"></script>
